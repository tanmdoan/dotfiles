export PGGSSENCMODE="disable"
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# aliases
alias hb-admin="LOAD_ACTIVE_ADMIN=1 foreman start"
alias hb-web="foreman start"
alias hb-setup="lsof -ti:3000,3500 | xargs kill -9 2>/dev/null; cd client && bun install && cd .. && bundle && be rails db:migrate && hb-admin"     